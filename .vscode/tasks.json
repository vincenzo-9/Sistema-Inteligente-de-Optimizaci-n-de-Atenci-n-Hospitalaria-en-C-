{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Compilar hospital",
      "type": "shell",
      "command": "g++",
      "args": [
        "main.cpp",
        "src/*.cpp",
        "-Iinclude",
        "-o",
        "hospital",
        "-std=c++17",
        "-Wall",
        "-Wextra",
        "-pedantic"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$gcc"
    }
  ]
}
